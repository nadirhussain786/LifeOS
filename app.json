{
  "expo": {
    "name": "LifeOS",
    "slug": "LifeOS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lifeos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "LifeOS uses your microphone to record voice notes and journal recordings."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LifeOS accesses your photos so you can attach them to notes and journal entries.",
          "cameraPermission": "LifeOS uses your camera so you can capture photos for notes and journal entries."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LifeOS uses your location to tag where a journal entry was written.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-notifications"
    ]
  }
}
