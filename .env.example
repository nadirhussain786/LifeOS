# LifeOS environment — copy this file to `.env` and fill in your values.
#
# Setup:
#   1. Create a Supabase project at https://supabase.com.
#   2. In the SQL editor, run supabase/migrations/0001_init.sql
#      (creates the profiles + sync tables with Row Level Security).
#   3. Copy the values below from Project Settings > API.
#
# The EXPO_PUBLIC_ prefix is required for Expo to inline these at build time.
# The anon key is safe to expose client-side: it only grants what your
# Postgres Row Level Security policies allow (each user sees only their rows).
#
# Without valid values, sign-in and sync won't work (guest mode still does).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: where the password-reset email links back to. Leave blank to use
# the app's built-in `lifeos://reset-password` deep link. If you set a custom
# value, also add it to your Supabase Auth "Redirect URLs" allow-list.
EXPO_PUBLIC_SUPABASE_REDIRECT_URL=

# ---------------------------------------------------------------------------
# EAS builds: local `.env` is NOT uploaded to EAS. Provide the same values to
# cloud builds either by filling the `env` blocks in eas.json, or (preferred)
# with EAS environment variables:
#   eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_URL --value "https://..."
#   eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..."
# (repeat for the development / preview environments as needed).