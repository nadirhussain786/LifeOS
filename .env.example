# Supabase project settings (Project Settings > API)
# EXPO_PUBLIC_ prefix is required for Expo to inline these at build time.
# These are safe to expose client-side: the anon key only grants access
# permitted by your Postgres Row Level Security policies.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
